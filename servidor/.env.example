# Mercado Pago (sandbox para prototipo)
MP_ACCESS_TOKEN=
MP_USER_ID=3420512522
MP_EXTERNAL_POS_ID=MATEPOINT001POS001
MP_WEBHOOK_SECRET=
# Precio por porción (ARS) — cambiar aquí / Railway sin tocar firmware
MP_SALE_AMOUNT=500.00

# MQTT — ver servidor-mate-point.md §3.2 (alternativas)
# Opción A — broker público HiveMQ (prototipo, sin cuenta):
MQTT_BROKER_URL=wss://broker.hivemq.com:8884/mqtt
# Opción B — broker público TCP (solo si el cliente soporta mqtt:// sin TLS):
# MQTT_BROKER_URL=mqtt://broker.hivemq.com:1883
# Opción C — HiveMQ Cloud (cuenta gratuita, MQTT TLS 8883):
# MQTT_BROKER_URL=ssl://xxxx.s1.eu.hivemq.cloud:8883
# MQTT_USER=
# MQTT_PASS=

MQTT_DEVICE_ID=MATEPOINT001
DISPENSE_DURATION_MS=120000

# App
PORT=3000
NODE_ENV=development
